PROJECT_NAME=Project Yamato Shanghai
VERSION=0.1.0
DESCRIPTION=Project Yamato Shanghai API
ENVIRONMENT=development
DEBUG=True
API_V1_STR=/api/v1

HOST=0.0.0.0
PORT=8000
ALLOWED_HOSTS=["*"]

POSTGRES_SERVER=127.0.0.1
POSTGRES_USER=pguser
POSTGRES_PASSWORD=pgvector123
POSTGRES_DB=pgdb
POSTGRES_PORT=5432

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://:change_me_redis_password@127.0.0.1:6379/0

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change_me_minio_password
MINIO_SECURE=false
MINIO_BUCKET_NAME=yamatodev

DOTS_OCR_ENDPOINT=http://REDACTED_PUBLIC_IP:60086/ocr/dotsocr/v1/chat/completions

BGE_M3_API_URL=http://REDACTED_PUBLIC_IP:60086/embeddings/v1/embeddings
RERANKER_API_URL=http://REDACTED_PUBLIC_IP:60086/reranker/v1/rerank

SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_API_KEY=internal-api-key

ENABLE_RATE_LIMIT=False
ENABLE_REQUEST_SIZE_LIMIT=True
ENABLE_CACHE=False
RATE_LIMIT_AUTH=100
RATE_LIMIT_ANON=20
RATE_LIMIT_WINDOW=60

MAX_JSON_SIZE=5242880
MAX_FILE_SIZE=52428800
CACHE_DEFAULT_TTL=300
CACHE_ENABLED_METHODS=["GET"]
CACHE_TTL=3600

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

ENABLE_METRICS=True
METRICS_PORT=9090
ENABLE_MONITORING=True
MONITORING_INTERVAL=60
ENABLE_PROMETHEUS=True
ENABLE_HEALTH_CHECK=True
# HuggingFace Mirror
HF_ENDPOINT=https://hf-mirror.com

# Local Models GPU Configuration (Tokenizer, PaddleOCR, etc.)
# 本地模型使用的GPU设备（不影响Docker部署的模型）
LOCAL_MODEL_GPU_DEVICE=0

CHAT_API_KEY=change_me_chat_api_key

# Chat frontend (apps/chat) Vite env
VITE_PORT=8888
VITE_API_BASE_URL=/api/v1
VITE_DIFY_TARGET=http://127.0.0.1:60086
VITE_DIFY_API_PREFIX=/v1
VITE_BACKEND_TARGET=http://127.0.0.1:60080
# Proxy-only secret for Dify auth (server-side in Vite proxy, not used in browser code)
CHAT_PROXY_API_KEY=change_me_chat_api_key
VITE_ENV=development
VITE_LOGIN_ENDPOINT=/auth/login
VITE_ME_ENDPOINT=/auth/me
VITE_AUTH_TOKEN_KEY=yamato_chat_token
VITE_SETTINGS_STORAGE_KEY=yamato_chat_settings
PROJECT_NAME=Project Yamato Shanghai
VERSION=1.0.1
DESCRIPTION=Project Yamato Shanghai API
ENVIRONMENT=development
DEBUG=True
API_V1_STR=/api/v1

HOST=0.0.0.0
PORT=8000
# 生产环境请改为明确域名清单，例如: ["api.example.com"]
ALLOWED_HOSTS=["*"]
TRUST_PROXY_HEADERS=False
TRUSTED_PROXIES=["127.0.0.1","10.0.0.0/8"]

POSTGRES_SERVER=127.0.0.1
POSTGRES_USER=pguser
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=pgdb
POSTGRES_PORT=5432

# SQL Server (U8 / PDM)
U8_SQLSERVER_HOST=127.0.0.1
U8_SQLSERVER_PORT=1433
U8_SQLSERVER_DATABASE=change_me_u8_database
U8_SQLSERVER_USER=sa
U8_SQLSERVER_PASSWORD=change_me_u8_sqlserver_password
U8_SQLSERVER_ENCRYPT=False

PDM_SQLSERVER_HOST=127.0.0.1
PDM_SQLSERVER_PORT=1433
PDM_SQLSERVER_DATABASE=change_me_pdm_database
PDM_SQLSERVER_USER=sa
PDM_SQLSERVER_PASSWORD=change_me_pdm_sqlserver_password
PDM_SQLSERVER_ENCRYPT=False

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://:your_redis_password@127.0.0.1:6379/0

MINIO_ENDPOINT=127.0.0.1:9000
# Optional public endpoint used when generating object URLs for external consumers (e.g. OCR service).
# If unset, MINIO_ENDPOINT is used.
MINIO_PUBLIC_ENDPOINT=
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key
MINIO_SECURE=false
MINIO_BUCKET_NAME=yamatodev

DOTS_OCR_ENDPOINT=http://localhost:80/ocr/dotsocr/v1/chat/completions

BGE_M3_API_URL=http://localhost:80/embeddings/v1/embeddings
RERANKER_API_URL=http://localhost:80/reranker/v1/rerank
QWEN3_8B_API_URL=http://localhost:80/llm/qwen8b/v1
QWEN3_8B_MODEL=Qwen/Qwen3-8B-FP8
QWEN3_6_35B_API_URL=http://localhost:80/llm/qwen36b/v1
# Must match id from: curl -s "$QWEN3_6_35B_API_URL/models" | jq
QWEN3_6_35B_MODEL=/models/Qwen3.6-35B-A3B

# Web search backend for the conversation workflow (replaces the Dify SearXNG plugin).
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=

# Conversation workflow concurrency caps (bound in-flight LLM calls + retrieval
# threads so a burst of chat users cannot exhaust vLLM or process threads).
# CONVERSATION_8B_MAX_CONCURRENT=20
# CONVERSATION_35B_MAX_CONCURRENT=10
# CONVERSATION_RETRIEVAL_MAX_WORKERS=8

# Remark LLM interpreter: when a spec sheet carries a remark, Qwen3.6-35B reads
# it and emits {canonical_field: adjusted_value} overrides applied before PDM
# matching. Any failure (no model service, timeout, bad output) degrades
# gracefully to the original pipeline behavior.
REMARK_LLM_INTERPRETER_ENABLED=true
REMARK_LLM_REQUEST_TIMEOUT=30
REMARK_LLM_MAX_TOKENS=512

SECRET_KEY=change_me_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_API_KEY=change_me_internal_api_key

RETRIEVER_ALLOWED_COLLECTIONS=["change-me-collection-name-1"]
RATE_LIMIT_EXPENSIVE_AUTH=40
RATE_LIMIT_EXPENSIVE_ANON=5
RATE_LIMIT_FAIL_OPEN=True
RATE_LIMIT_REDIS_ERROR_STATUS=503


# 仅开发环境按需启用；生产环境建议不要配置引导超级管理员
# BOOTSTRAP_SUPERUSER_USERNAME=superuser
# BOOTSTRAP_SUPERUSER_EMAIL=superuser@example.com
# BOOTSTRAP_SUPERUSER_PASSWORD=change_me_superuser_password

ENABLE_RATE_LIMIT=True
ENABLE_REQUEST_SIZE_LIMIT=True
ENABLE_CACHE=False
RATE_LIMIT_AUTH=100
RATE_LIMIT_ANON=20
RATE_LIMIT_WINDOW=60

MAX_JSON_SIZE=5242880
MAX_FILE_SIZE=52428800
CACHE_DEFAULT_TTL=300
CACHE_ENABLED_METHODS=["GET"]
CACHE_TTL=3600

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

ENABLE_METRICS=True
METRICS_PORT=9090
ENABLE_MONITORING=True
MONITORING_INTERVAL=60
ENABLE_PROMETHEUS=True
ENABLE_HEALTH_CHECK=True
METRICS_REQUIRE_API_KEY=True
ENABLE_SECURITY_HEADERS=True
ENABLE_HSTS=True
HSTS_MAX_AGE=31536000
# HuggingFace Mirror
HF_ENDPOINT=https://hf-mirror.com

# Local Models GPU Configuration (Tokenizer, PaddleOCR, etc.)
# 本地模型使用的GPU设备（不影响Docker部署的模型）
LOCAL_MODEL_GPU_DEVICE=3

# ==========================================================================
# 以下为 config.py 中可由环境变量覆盖、但默认未登记的运维调参项。
# 默认值与 config.py 一致；部署时按需取消注释并调整。
# ==========================================================================

# ---- DB 连接池（PostgreSQL，app/core/database.py 消费）----
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
# DB_POOL_TIMEOUT=30
# DB_POOL_RECYCLE=3600
# REDIS_MAX_CONNECTIONS=10

# ---- 后台任务线程池（executor.py）----
# EXECUTOR_MAX_WORKERS=30

# ---- SQL Server（U8/PDM）查询与熔断 ----
# SQLSERVER_QUERY_TIMEOUT_SEC=120
# SQLSERVER_LOGIN_TIMEOUT_SEC=30
# SQLSERVER_QUERY_MAX_WORKERS=2
# SQLSERVER_CB_FAIL_THRESHOLD=5
# SQLSERVER_CB_OPEN_SEC=60

# ---- U8 BOM 并发 / ERP 连接闸门 ----
# U8_BOM_PARALLEL_WORKERS=16
# U8_BOM_MAX_CONCURRENT_TASKS=30
# U8_BOM_MAX_CONCURRENT_TASKS_PER_USER=2
# U8_BOM_MAX_TOTAL_CONNECTIONS=64
# U8_BOM_POOL_ACQUIRE_TIMEOUT_SEC=60

# ---- GPU 模型池（PaddleOCR / TagGenerator）----
# PADDLEOCR_POOL_MAX_SIZE=5
# PADDLEOCR_ACQUIRE_TIMEOUT_SEC=30
# TAGGENERATOR_POOL_MAX_SIZE=5
# TAGGENERATOR_ACQUIRE_TIMEOUT_SEC=30

# ---- OCR HTTP / 文本提取 ----
# OCR_HTTP_CONNECT_TIMEOUT=10.0
# OCR_HTTP_READ_TIMEOUT=300.0
# OCR_PDFTEXT_ENABLED=True
# OCR_PDFTEXT_TIMEOUT=30
# OCR_DOTSOCR_MAX_TOKENS=4096

# ---- HTTP 客户端 ----
# HTTP_CLIENT_TIMEOUT=30.0
# HTTP_CLIENT_MAX_CONNECTIONS=100
# HTTP_CLIENT_MAX_KEEPALIVE=20

# ---- MinIO 细项 ----
# MINIO_APP_ENDPOINT=127.0.0.1:9000
# MINIO_REGION=us-east-1
# MINIO_PRESIGN_EXPIRES_HOURS=12
# MINIO_PRESIGN_SECURE=
# MINIO_DOWNLOAD_TIMEOUT_SEC=60.0
# MinIO 幽灵文件对账（与 DB 比对删除未引用对象）。
# 扫描间隔与宽限期默认均为 3 天；因宽限期==间隔，孤儿对象最坏需约
# 2 个周期（≈6 天）才会被清理。如需更紧的清理，调小 GRACE 使其 < INTERVAL。
# MINIO_RECONCILE_INTERVAL_SEC=259200
# MINIO_RECONCILE_GRACE_SEC=259200
# MINIO_OCR_TEMP_BUCKET=
# MINIO_OCR_ENABLE_ANONYMOUS_BUCKET=False
# MINIO_OCR_ANONYMOUS_BUCKET=

# ---- 限流（额外分档）----
# RATE_LIMIT_REQUESTS_PER_MINUTE=300
# RATE_LIMIT_REQUESTS_PER_HOUR=3000
# RATE_LIMIT_AUTH_ADMIN=1200
# RATE_LIMIT_EXPENSIVE_AUTH_ADMIN=240

# ---- WebSocket 并发 ----
# WS_MAX_CONNECTIONS_PER_IP=20
# WS_MAX_MESSAGES_PER_MINUTE=120
# WS_MAX_CONNECTIONS_PER_USER=16
# WS_MAX_CONNECTIONS_PER_USER_ADMIN=64
# WS_MAX_TRACKED_IPS_FOR_COUNTERS=2000

# ---- 报价任务运行时 ----
# QUOTATION_MAX_RUNNING_PER_OWNER=2
# QUOTATION_MAX_RUNNING_PER_IP=2
# QUOTATION_RETENTION_MAX_TOTAL=100
# QUOTATION_RETENTION_TARGET=50
# QUOTATION_RETENTION_INTERVAL_SEC=300
# QUOTATION_AWAITING_APPROVAL_TTL_HOURS=24
# QUOTATION_RUNNING_TIMEOUT_SEC=1800

# ---- 任务归属缓存 ----
# TASK_OWNER_CACHE_TTL_SEC=86400
# TASK_OWNER_CACHE_MAX=5000

# ---- 文档转换 ----
# LIBREOFFICE_SUBPROCESS_TIMEOUT_SEC=300

# ---- 日志轮转 ----
# LOG_FILE=
# LOG_MAX_BYTES=10485760
# LOG_BACKUP_COUNT=5

# ---- 缓存 TTL 细项 ----
# CACHE_API_RESPONSE_TTL=300
# CACHE_JOB_STATUS_TTL=86400

# ---- 文件上传 ----
# MAX_FILE_SIZE_MB=50
# ALLOWED_FILE_EXTENSIONS=.pdf,.doc,.docx,.txt,.csv,.xlsx,.xls,.json,.xml

# ---- Qwen3.6-35B served model id（须与 GET /v1/models 返回一致）----
# QWEN3_6_35B_MODEL=/models/Qwen3.6-35B-A3B

# ---- Remark LLM 解释器（规格书 remark → 字段调整）----
# REMARK_LLM_INTERPRETER_ENABLED=true
# REMARK_LLM_REQUEST_TIMEOUT=30
# REMARK_LLM_MAX_TOKENS=512

# ---- 集成平台（按需启用）----
# N8N_BASE_URL=http://localhost:5678
# N8N_API_KEY=
# RAGFLOW_BASE_URL=http://localhost:9380
# RAGFLOW_API_KEY=
# RAGFLOW_DATASET_ID=
# SUPERSET_BASE_URL=http://localhost:8088
# SUPERSET_USERNAME=admin
# SUPERSET_PASSWORD=change_me_superset_password
# SUPERSET_DATABASE_ID=1
# SUPERSET_GUEST_TOKEN_SECRET=change_me_superset_guest_token_secret
# SUPERSET_CSRF_TOKEN_TIMEOUT=3600
# SUPERSET_CACHE_DEFAULT_TIMEOUT=300
# DATAHUB_GMS_URL=http://localhost:8080
# DATAHUB_GMS_TOKEN=
# DATAHUB_KAFKA_BOOTSTRAP_SERVERS=localhost:9092
# DATAHUB_SCHEMA_REGISTRY_URL=http://localhost:8081

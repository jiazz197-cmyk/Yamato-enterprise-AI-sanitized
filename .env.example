PROJECT_NAME=Project Yamato Shanghai
VERSION=0.1.0
DESCRIPTION=Project Yamato Shanghai API
ENVIRONMENT=development
DEBUG=True
API_V1_STR=/api/v1

HOST=0.0.0.0
PORT=8000
ALLOWED_HOSTS=["*"]

POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_pg_password
POSTGRES_DB=postgres
POSTGRES_PORT=5432

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=change_me_redis_password
REDIS_URL=redis://:change_me_redis_password@localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
MINIO_BUCKET_NAME=imagebed

DOTS_OCR_ENDPOINT=http://localhost:8001/v1/chat/completions

BGE_M3_API_URL=http://localhost:8002/v1/embeddings
RERANKER_API_URL=http://localhost:8003/v1/rerank

SECRET_KEY=change-me
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_API_KEY=internal-api-key

ENABLE_RATE_LIMIT=False
ENABLE_REQUEST_SIZE_LIMIT=True
ENABLE_CACHE=False
RATE_LIMIT_AUTH=100
RATE_LIMIT_ANON=20
RATE_LIMIT_WINDOW=60

MAX_JSON_SIZE=5242880
MAX_FILE_SIZE=52428800
CACHE_DEFAULT_TTL=300
CACHE_ENABLED_METHODS=["GET"]
CACHE_TTL=3600

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

ENABLE_METRICS=True
METRICS_PORT=9090
ENABLE_MONITORING=True
MONITORING_INTERVAL=60
ENABLE_PROMETHEUS=True
ENABLE_HEALTH_CHECK=True
# HuggingFace Mirror
HF_ENDPOINT=https://hf-mirror.com

# Local Models GPU Configuration (Tokenizer, PaddleOCR, etc.)
# 本地模型使用的GPU设备（不影响Docker部署的模型）
LOCAL_MODEL_GPU_DEVICE=3

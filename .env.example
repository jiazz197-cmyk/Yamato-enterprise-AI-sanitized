PROJECT_NAME=Project Yamato Shanghai
VERSION=0.1.0
DESCRIPTION=Project Yamato Shanghai API
ENVIRONMENT=development
DEBUG=True
API_V1_STR=/api/v1

HOST=0.0.0.0
PORT=8000
# 生产环境请改为明确域名清单，例如: ["api.example.com"]
ALLOWED_HOSTS=["*"]
TRUST_PROXY_HEADERS=False
TRUSTED_PROXIES=127.0.0.1,10.0.0.0/8

POSTGRES_SERVER=127.0.0.1
POSTGRES_USER=pguser
POSTGRES_PASSWORD=change_me_postgres_password
POSTGRES_DB=pgdb
POSTGRES_PORT=5432

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_URL=redis://:your_redis_password@127.0.0.1:6379/0

MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=change_me_minio_access_key
MINIO_SECRET_KEY=change_me_minio_secret_key
MINIO_SECURE=false
MINIO_BUCKET_NAME=yamatodev

DOTS_OCR_ENDPOINT=http://localhost:80/ocr/dotsocr/v1/chat/completions

BGE_M3_API_URL=http://localhost:80/embeddings/v1/embeddings
RERANKER_API_URL=http://localhost:80/reranker/v1/rerank
QWEN3_8B_API_URL=http://localhost:80/llm/qwen8b/v1
QWEN3.5_27B_API_URL=http://localhost:80/llm/qwen8b/v1

SECRET_KEY=change_me_secret_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
INTERNAL_API_KEY=change_me_internal_api_key

RETRIEVER_ALLOWED_COLLECTIONS=["change-me-collection-name-1"]
RATE_LIMIT_EXPENSIVE_AUTH=40
RATE_LIMIT_EXPENSIVE_ANON=5
RATE_LIMIT_FAIL_OPEN=True
RATE_LIMIT_REDIS_ERROR_STATUS=503


# 仅开发环境按需启用；生产环境建议不要配置引导超级管理员
# BOOTSTRAP_SUPERUSER_USERNAME=superuser
# BOOTSTRAP_SUPERUSER_EMAIL=superuser@example.com
# BOOTSTRAP_SUPERUSER_PASSWORD=change_me_superuser_password

ENABLE_RATE_LIMIT=True
ENABLE_REQUEST_SIZE_LIMIT=True
ENABLE_CACHE=False
RATE_LIMIT_AUTH=100
RATE_LIMIT_ANON=20
RATE_LIMIT_WINDOW=60

MAX_JSON_SIZE=5242880
MAX_FILE_SIZE=52428800
CACHE_DEFAULT_TTL=300
CACHE_ENABLED_METHODS=["GET"]
CACHE_TTL=3600

LOG_LEVEL=INFO
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

ENABLE_METRICS=True
METRICS_PORT=9090
ENABLE_MONITORING=True
MONITORING_INTERVAL=60
ENABLE_PROMETHEUS=True
ENABLE_HEALTH_CHECK=True
METRICS_REQUIRE_API_KEY=True
ENABLE_SECURITY_HEADERS=True
ENABLE_HSTS=True
HSTS_MAX_AGE=31536000
# HuggingFace Mirror
HF_ENDPOINT=https://hf-mirror.com

# Local Models GPU Configuration (Tokenizer, PaddleOCR, etc.)
# 本地模型使用的GPU设备（不影响Docker部署的模型）
LOCAL_MODEL_GPU_DEVICE=3

CHAT_API_KEY=change_me_chat_api_key
